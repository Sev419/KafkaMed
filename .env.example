# Example environment variables for local development.
# Do not store real credentials in this file.

MONGO_URI=mongodb://mongo:27017
MONGO_DB_NAME=kafkamed_db
MONGO_COLLECTION=heart_records
MONGO_PREDICTIONS_COLLECTION=heart_predictions
MONGO_ENABLED=true
MODEL_PATH=ml/models/heart_risk_model.joblib
MODEL_VERSION=logistic_regression_complete_dataset_v1

# Flask API configuration.
API_HOST=127.0.0.1
API_PORT=8000

# Micro-batch simulation.
STREAM_BATCH_SIZE=25
STREAM_MAX_BATCHES=3
SPARK_MASTER=local[1]
SPARK_SHUFFLE_PARTITIONS=1
SPARK_DEFAULT_PARALLELISM=1
SPARK_UI_ENABLED=false
SPARK_DRIVER_BIND_ADDRESS=127.0.0.1
SPARK_DRIVER_HOST=127.0.0.1

# KafkaMed - fase 1.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=heart-records
HEART_DATASET_PATH=data/raw/heart_failure_prediction.csv
PRODUCER_INTERVAL_SECONDS=0.5
PRODUCER_LIMIT=0
SPARK_CHECKPOINT_LOCATION=/tmp/kafkamed/checkpoints/heart-records-mongo
SPARK_STARTING_OFFSETS=earliest

# Optional SMS alerts.
ALERTS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_TO_NUMBER=
